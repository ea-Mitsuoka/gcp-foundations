# Terraform files to ignore
.terraform/
.terraform.lock.hcl
.terraform-version
*.tfstate
*.tfstate.*
*.tfvars
*.tfbackend
tfplan
**/auto_*.tf

# Environment files
domain.env
env
gcp-foundations.xlsx

# Sphinx documentation build
build/

# Automatically created terraform files
/terraform/4_projects/*
!/terraform/4_projects/template/
**/auto_*.tf

# Python cache files
__pycache__/

# IDE files
.netrc

# Other files
memo*
.DS_Store
.catignore
list-files-for-ai.sh
cat-for-ai.sh
file_list.txt
all_contents.txt
change.patch
.catignore
gemini/
koushiki/
.deploy_state
notifications.csv
alert_definitions.csv
gcp_log_sink_config.csv

# Test mode environment variable file
.test_mode_env

migration/
# docs/migration 配下は原則無視（顧客固有の assessment/plan 等の作業成果物）。
# ただし汎用の取り込み手順（再利用可能なドキュメント）だけは追跡する。
!docs/migration/
docs/migration/*
!docs/migration/project_migration_risk_check.md

# Excel temporary lock files
~$*.xlsx

# 納品物（make delivery / make delivery-doc が自動生成する構築設定明細書）。
# テンプレートリポジトリでは追跡しない（顧客固有データを含むため）。
# handover.sh が除外を解除し、顧客への納品リポジトリには同梱される。
delivery/
ea-design/
